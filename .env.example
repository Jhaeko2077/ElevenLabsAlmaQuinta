# Entorno de ejecución: development, test o production.
NODE_ENV=development

# Puerto HTTP del backend.
PORT=3000

# Versión que expone GET / y que se imprime en logs.
APP_VERSION=1.0.0

# Nivel de logs de Pino: fatal, error, warn, info, debug o trace.
LOG_LEVEL=info

# Origen permitido para CORS. Usa * para desarrollo o una lista separada por comas.
CORS_ORIGIN=*

# Secreto compartido con ElevenLabs. Debe coincidir exactamente con el header X-Agent-API-Key.
AGENT_API_KEY=replace-with-a-long-random-secret

# Timezone del negocio. Debe coincidir con la variable business_timezone del agente.
BUSINESS_TIMEZONE=America/Lima

# Hora de inicio de atención en formato HH:mm.
BUSINESS_HOURS_START=09:00

# Hora de fin de atención en formato HH:mm.
BUSINESS_HOURS_END=18:00

# Duración por defecto de cada reunión en minutos.
DEFAULT_MEETING_DURATION_MINUTES=30

# Project ID de Google Cloud tomado del JSON de la service account.
GOOGLE_PROJECT_ID=your-google-project-id

# Client email de la service account. Este es también el email con el que debes compartir el calendario.
GOOGLE_CLIENT_EMAIL=service-account-name@your-project.iam.gserviceaccount.com

# Private key de la service account. Pégala escapando saltos de línea como \n.
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n

# Calendar ID del calendario de Google a consultar y editar.
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Número humano real para escalamientos.
HANDOFF_PHONE=+51999999999

# Referencia opcional de agenda o link de respaldo.
BOOKING_REFERENCE=https://almaquinta.example.com/agenda

# Carpeta local para persistencia simple.
DATA_DIR=./data

# Habilita o deshabilita la exposición de métricas Prometheus.
ENABLE_METRICS=true

# Ventana del rate limiting en milisegundos.
RATE_LIMIT_WINDOW_MS=60000

# Máximo de requests por IP dentro de la ventana.
RATE_LIMIT_MAX_REQUESTS=60
